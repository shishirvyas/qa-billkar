{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@qa/*": ["./*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "setup/**/*.ts",
    "pages/**/*.ts",
    "utils/**/*.ts",
    "fixtures/**/*.ts",
    "reporter/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist", "reports"]
}
