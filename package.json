{
  "name": "qa-billkar",
  "version": "1.0.0",
  "description": "Production-grade autonomous QA system for Billkar",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:smoke": "node scripts/run-smoke.mjs",
    "test:full": "node scripts/run-full.mjs",
    "test:billing": "playwright test tests/billing/ tests/billing.spec.ts",
    "test:customers": "playwright test tests/customers/",
    "test:products": "playwright test tests/products/",
    "test:inventory": "playwright test tests/inventory/ tests/inventory.spec.ts",
    "test:auth": "playwright test tests/auth/ tests/auth.spec.ts",
    "test:sync": "playwright test tests/sync/ tests/sync.spec.ts",
    "test:reports": "playwright test tests/reports/ tests/reports.spec.ts",
    "test:permissions": "playwright test tests/permissions/ tests/permissions.spec.ts",
    "test:settings": "playwright test tests/settings/",
    "test:perf": "playwright test tests/performance/",
    "test:offline": "playwright test tests/sync/offline.spec.ts",
    "test:ci": "playwright test --reporter=github,html,json",
    "test:nightly": "playwright test --reporter=html,json && node reporter/generateDashboard.mjs",
    "check:results": "node scripts/check-results.mjs",
    "report": "playwright show-report reports/playwright-html",
    "allure:open": "allure open allure-report",
    "dashboard": "node reporter/generateDashboard.mjs",
    "orchestrate": "node agent/orchestrator.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "allure-playwright": "^2.9.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.0"
  }
}
