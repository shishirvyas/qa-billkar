# ── Billkar QA Environment ────────────────────────────────────────────────────
# Copy to .env and fill in real values (never commit .env)

# Target app URL (default: Vite dev server)
QA_BASE_URL=http://localhost:5173

# Backend API for direct DB/API assertions
QA_API_URL=http://localhost:3000

# Credentials injected into the bridge mock (or real login if not using mock)
QA_ADMIN_EMAIL=admin@acme.com
QA_ADMIN_PASSWORD=TestAdmin@123

QA_MANAGER_EMAIL=manager@acme.com
QA_MANAGER_PASSWORD=TestManager@123

QA_CASHIER_EMAIL=cashier@acme.com
QA_CASHIER_PASSWORD=TestCashier@123

# Tenant context defaults
QA_TENANT_ID=t-1
QA_TENANT_SLUG=acme
QA_STORE_ID=s-1
